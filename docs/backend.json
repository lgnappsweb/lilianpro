{
  "entities": {
    "Client": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Client",
      "type": "object",
      "description": "Represents a customer profile.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "adminId": { "type": "string" }
      },
      "required": ["id", "fullName", "phone", "registrationDate", "adminId"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product in the catalog.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "salePrice": { "type": "number" },
        "costPrice": { "type": "number" },
        "catalogPrice": { "type": "number" },
        "productCode": { "type": "string" },
        "description": { "type": "string" },
        "adminId": { "type": "string" }
      },
      "required": ["id", "name", "brand", "category", "salePrice", "adminId"]
    },
    "Order": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Order",
      "type": "object",
      "description": "Represents a sales transaction.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "totalAmount": { "type": "number" },
        "discountAmount": { "type": "number" },
        "additionalFeeAmount": { "type": "number" },
        "finalAmount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "adminId": { "type": "string" }
      },
      "required": ["id", "clientId", "orderDate", "paymentMethod", "paymentStatus", "finalAmount", "adminId"]
    },
    "OrderItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "OrderItem",
      "type": "object",
      "description": "An item within an order.",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "subtotal": { "type": "number" },
        "adminId": { "type": "string" }
      },
      "required": ["id", "orderId", "productId", "productName", "quantity", "unitPrice", "subtotal", "adminId"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "adminId": { "type": "string" }
      },
      "required": ["id", "name", "adminId"]
    },
    "Settings": {
      "title": "Settings",
      "type": "object",
      "properties": {
        "appName": { "type": "string" },
        "primaryColor": { "type": "string" },
        "themeMode": { "type": "string", "enum": ["light", "dark"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "description": "Root for user-owned data silo."
        }
      },
      {
        "path": "/users/{userId}/clients/{clientId}",
        "definition": {
          "entityName": "Client",
          "schema": { "$ref": "#/backend/entities/Client" },
          "description": "Customer records for the user."
        }
      },
      {
        "path": "/users/{userId}/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": { "$ref": "#/backend/entities/Product" },
          "description": "Product catalog for the user."
        }
      },
      {
        "path": "/users/{userId}/orders/{orderId}",
        "definition": {
          "entityName": "Order",
          "schema": { "$ref": "#/backend/entities/Order" },
          "description": "Sales records for the user."
        }
      },
      {
        "path": "/users/{userId}/orders/{orderId}/orderItems/{itemId}",
        "definition": {
          "entityName": "OrderItem",
          "schema": { "$ref": "#/backend/entities/OrderItem" },
          "description": "Items within a specific sale."
        }
      },
      {
        "path": "/users/{userId}/categories/{categoryId}",
        "definition": {
          "entityName": "Category",
          "schema": { "$ref": "#/backend/entities/Category" },
          "description": "Product categories for the user."
        }
      },
      {
        "path": "/users/{userId}/config/settings",
        "definition": {
          "entityName": "Settings",
          "schema": { "$ref": "#/backend/entities/Settings" },
          "description": "Application personalization settings."
        }
      }
    ]
  }
}