{
  "entities": {
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Representa um perfil de cliente/comprador.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "neighborhood": { "type": "string" },
        "address": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "adminId": { "type": "string" }
      },
      "required": ["id", "fullName", "phone", "registrationDate", "adminId"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Item do catálogo de produtos.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "salePrice": { "type": "number" },
        "costPrice": { "type": "number" },
        "catalogPrice": { "type": "number" },
        "productCode": { "type": "string" },
        "description": { "type": "string" },
        "adminId": { "type": "string" }
      },
      "required": ["id", "name", "brand", "salePrice", "adminId"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "Registro de uma venda realizada.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "totalAmount": { "type": "number" },
        "discountAmount": { "type": "number" },
        "additionalFeeAmount": { "type": "number" },
        "finalAmount": { "type": "number" },
        "dueDate": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "adminId": { "type": "string" }
      },
      "required": ["id", "clientId", "orderDate", "paymentMethod", "paymentStatus", "finalAmount", "adminId"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "type": "object",
      "description": "Item individual dentro de um pedido.",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "subtotal": { "type": "number" },
        "adminId": { "type": "string" }
      },
      "required": ["id", "orderId", "productId", "productName", "quantity", "unitPrice", "subtotal", "adminId"]
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "adminId": { "type": "string" }
      },
      "required": ["id", "name", "adminId"]
    },
    "Settings": {
      "title": "Settings",
      "type": "object",
      "properties": {
        "appName": { "type": "string" },
        "primaryColor": { "type": "string" },
        "themeMode": { "type": "string", "enum": ["light", "dark"] }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "description": "Documento raiz do silo do usuário."
    },
    "/users/{userId}/clients/{clientId}": {
      "schema": { "$ref": "#/backend/entities/Client" },
      "description": "Cadastro de clientes do usuário."
    },
    "/users/{userId}/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Catálogo de produtos do usuário."
    },
    "/users/{userId}/categories/{categoryId}": {
      "schema": { "$ref": "#/backend/entities/Category" },
      "description": "Categorias de produtos."
    },
    "/users/{userId}/orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/Order" },
      "description": "Histórico de vendas."
    },
    "/users/{userId}/orders/{orderId}/orderItems/{itemId}": {
      "schema": { "$ref": "#/backend/entities/OrderItem" },
      "description": "Itens detalhados de cada venda."
    },
    "/users/{userId}/config/settings": {
      "schema": { "$ref": "#/backend/entities/Settings" },
      "description": "Configurações de personalização do app."
    }
  }
}