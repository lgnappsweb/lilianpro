rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model. Every piece of data 
     * (Clients, Products, Orders, Categories, Config) is nested under a specific 
     * user's UID in the document path: /users/{userId}/...
     *
     * KEY SECURITY DECISIONS:
     * 1. Path-Based Authorization: The 'userId' wildcard in the URL is the source of truth. 
     *    A user can only access data if their authenticated UID matches the 'userId' in the path.
     * 2. Recursive Access: Once ownership of the root user document is established, 
     *    access is granted to all nested collections and documents.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User root and all its sub-resources.
     * Covers: /users/{userId}/clients, /users/{userId}/orders, etc.
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}