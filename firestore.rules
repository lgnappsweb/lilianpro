rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ESTRUTURA DE SILO POR USUÁRIO
     * Garante que cada usuário tenha acesso total e exclusivo aos seus próprios dados.
     * O padrão {document=**} aplica a regra recursivamente a todas as subcoleções.
     */

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Fallback de segurança para negar qualquer acesso que não se enquadre no silo acima
    match /{document=**} {
      allow read, write: if false;
    }
  }
}