rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLAMGESTÃO - REGRAS DE SEGURANÇA ELITE
     * 
     * Modelo: Propriedade Total do Usuário (Single-Tenant Path)
     * Descrição: Qualquer usuário autenticado tem controle absoluto sobre 
     * os dados localizados no seu próprio caminho /users/{uid}/...
     */

    // Verifica se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o UID do usuário corresponde ao caminho solicitado
    function isOwner(adminId) {
      return isSignedIn() && request.auth.uid == adminId;
    }

    // Regra Recursiva: Cobre clientes, produtos, pedidos e subcoleções
    match /users/{adminId}/{document=**} {
      allow read, write: if isOwner(adminId);
    }

    // Registro de administradores (DBAC - Mantido para compatibilidade)
    match /admins/{adminId} {
      allow get: if isOwner(adminId);
      allow list, write: if false;
    }
  }
}