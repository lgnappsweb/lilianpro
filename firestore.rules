rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * GLAMGESTÃO / LILIANPRO - REGRAS DE SEGURANÇA ELITE
     * 
     * Modelo: Propriedade Total do Usuário (Single-Tenant Path)
     * Descrição: Garante que apenas o proprietário autenticado possa acessar seus dados.
     */

    // Verifica se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o UID do usuário corresponde ao adminId do caminho
    function isOwner(adminId) {
      return isSignedIn() && request.auth.uid == adminId;
    }

    // Regra Recursiva Robusta: Cobre a raiz do usuário e TODAS as subcoleções (clientes, produtos, pedidos, etc.)
    match /users/{adminId} {
      allow read, write: if isOwner(adminId);
      
      match /{allPaths=**} {
        allow read, write: if isOwner(adminId);
      }
    }

    // Registro de administradores (Somente leitura pontual permitida para o próprio usuário)
    match /admins/{adminId} {
      allow get: if isOwner(adminId);
      allow list, write: if false;
    }
  }
}