rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LILIANPRO - REGRAS DE SEGURANÇA ELITE
     * 
     * Modelo: Propriedade Total do Usuário (Single-Tenant Path)
     * Garante que apenas o proprietário autenticado possa acessar seus dados.
     */

    // Verifica se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o UID do usuário corresponde ao adminId do caminho
    function isOwner(adminId) {
      return isSignedIn() && request.auth.uid == adminId;
    }

    // Regra Global para a árvore do usuário: abrange o documento do usuário e TODAS as subcoleções
    match /users/{adminId}/{allPaths=**} {
      allow read, write: if isOwner(adminId);
    }

    // Regra específica para o documento raiz do usuário (caso não seja capturado pelo curinga recursivo)
    match /users/{adminId} {
      allow read, write: if isOwner(adminId);
    }

    // Registro de administradores (Permite leitura pontual para verificação de acesso)
    match /admins/{adminId} {
      allow get: if isOwner(adminId);
      allow list, write: if false;
    }
  }
}