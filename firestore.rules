rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY: User Silo Pattern (v2 Robust)
     * Este sistema garante que cada usuário tenha acesso total e exclusivo
     * apenas aos seus próprios dados localizados no caminho /users/{userId}/...
     * 
     * A estrutura abaixo garante que tanto o documento raiz do usuário
     * quanto todas as subcoleções (pedidos, clientes, etc) herdem a permissão.
     */

    match /users/{userId} {
      // Permite acesso ao próprio documento do usuário
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Permite acesso recursivo a QUALQUER subcoleção ou documento aninhado
      // Isso resolve especificamente erros de 'list' em caminhos como /users/ID/orders
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Suporte para consultas que possam iniciar na raiz da coleção (opcional, mas seguro)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}