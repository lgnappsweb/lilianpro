rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LILIANPRO - REGRAS DE SEGURANÇA ELITE
     * 
     * Modelo: Propriedade Total do Usuário (Single-Tenant Path)
     * Garante que apenas o proprietário autenticado possa acessar seus dados.
     */

    // Verifica se o usuário está logado e é o dono dos dados no caminho
    function isOwner(adminId) {
      return request.auth != null && request.auth.uid == adminId;
    }

    // Regra Recursiva Monumental: Abrange o documento do usuário e TODAS as suas subcoleções
    // (clientes, produtos, categorias, pedidos, itens de pedidos, configurações, etc.)
    match /users/{adminId}/{document=**} {
      allow read, write: if isOwner(adminId);
    }

    // Regra específica para o nó raiz do usuário (caso necessário para metadados diretos)
    match /users/{adminId} {
      allow read, write: if isOwner(adminId);
    }

    // Registro de administradores (Permite leitura individual para verificação de perfil)
    match /admins/{adminId} {
      allow get: if isOwner(adminId);
      allow list, write: if false;
    }
  }
}