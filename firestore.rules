rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY: User Silo Pattern (v3 Clean)
     * Este sistema garante isolamento total de dados.
     * Cada usuário autenticado tem acesso exclusivo aos documentos
     * e subcoleções localizados sob o seu próprio ID.
     */

    match /users/{userId}/{document=**} {
      // Permite leitura e escrita se o usuário estiver autenticado 
      // e seu UID coincidir com o ID no caminho do documento.
      // O sufixo {document=**} garante que pedidos, clientes, produtos e 
      // configurações herdem esta permissão automaticamente.
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Regra adicional para o documento raiz do usuário (caso necessário para metadados)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}