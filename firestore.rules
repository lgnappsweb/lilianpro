rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY: User Silo Pattern
     * Este sistema garante que cada usuário (adminId) tenha acesso total e exclusivo
     * apenas aos seus próprios dados localizados no caminho /users/{userId}/...
     */

    // Verifica se o usuário está autenticado e se é o dono do diretório de dados
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Regra recursiva global para o Silo do Usuário
    // O padrão {document=**} garante que permissões sejam herdadas por todas
    // as subcoleções (clients, orders, orderItems, products, config, etc.)
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }
    
    // Suporte adicional para o nó raiz do usuário se necessário
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}