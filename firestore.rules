rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LILIANPRO - REGRAS DE SEGURANÇA ELITE
     * 
     * Modelo: Propriedade Total do Usuário (Single-Tenant Path)
     * Garante que apenas o proprietário autenticado possa acessar seus próprios dados.
     */

    // Verifica se o usuário está logado e se o UID coincide com o adminId do caminho
    function isOwner(adminId) {
      return request.auth != null && request.auth.uid == adminId;
    }

    // Regra Global para o nó do Usuário e TODAS as suas subcoleções
    // Isso garante que 'get', 'list', 'create', 'update' e 'delete' funcionem 
    // em caminhos como /users/{uid}, /users/{uid}/orders, /users/{uid}/clients, etc.
    match /users/{adminId} {
      allow read, write: if isOwner(adminId);
      
      match /{allPaths=**} {
        allow read, write: if isOwner(adminId);
      }
    }

    // Registro de administradores
    // Permite leitura individual (get) para validação de perfil
    match /admins/{adminId} {
      allow get: if isOwner(adminId);
      allow list, write: if false;
    }
  }
}