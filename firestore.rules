rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LILIANPRO - REGRAS DE SEGURANÇA ELITE
     * 
     * Modelo: Propriedade Total do Usuário (Recursive Path)
     * Garante que apenas o proprietário autenticado possa acessar seus próprios dados e subcoleções.
     */

    // Verifica se o usuário está logado e se o UID coincide com o proprietário do caminho
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Regra Global Recursiva para o nó do Usuário
    // O padrão {document=**} garante que permissões de read/write sejam aplicadas 
    // a todos os documentos e subcoleções (pedidos, clientes, produtos, etc)
    match /users/{userId}/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Registro de administradores
    // Permite leitura individual (get) para validação de perfil durante o login
    match /admins/{adminId} {
      allow get: if isOwner(adminId);
      allow list, write: if false;
    }
  }
}