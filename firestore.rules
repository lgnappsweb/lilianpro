rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ESTRUTURA DE SILO POR USUÁRIO
     * Garante que cada usuário acesse apenas seus próprios dados.
     */

    match /users/{userId} {
      // Permite acesso ao documento raiz do usuário
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Permite acesso recursivo a todas as subcoleções (clients, orders, products, etc)
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Fallback de segurança para negar qualquer outro acesso
    match /{document=**} {
      allow read, write: if false;
    }
  }
}